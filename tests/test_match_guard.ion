enum Option<T> {
    Some(T);
    None;
}

fn main() -> int {
    let value: Option<int> = Option::Some(10);
    match value {
        Option::Some(x) if x > 5 => {
            return 0;
        }
        Option::Some(_) => {
            return 1;
        }
        Option::None => {
            return 2;
        }
    };
}
