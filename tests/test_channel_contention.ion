// Four spawns each send on a dedicated channel; main sums received values.
fn producer_count() -> int {
    return 4;
}

fn spawn_producer(value: int, tx: Sender<int>) {
    spawn {
        send(&tx, value);
    };
}

fn main() -> int {
    let mut sum: int = 0;
    let mut i: int = 0;
    while i < producer_count() {
        let (tx, rx): (Sender<int>, Receiver<int>) = channel<int>();
        let value: int = (i + 1) * 10;
        spawn_producer(value, tx);
        let mut rx_mut: Receiver<int> = rx;
        let received: int = recv(&mut rx_mut);
        sum = sum + received;
        i = i + 1;
    }

    if sum != 100 {
        return 1;
    }
    return 73;
}
