// Rvalue match: mixed diverging and value-producing paths within one arm is rejected.
enum E {
    A(int);
    B(int);
}

fn main() -> int {
    let c: bool = true;
    let e: E = E::A(0);
    let n: int = match e {
        E::A(_) => {
            if c {
                return 1;
            } else {
                2;
            }
        },
        E::B(v) => {
            v;
        },
    };
    return n;
}
