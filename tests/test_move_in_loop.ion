// Moving a non-copy value inside a loop body is rejected: a second iteration
// would need the binding again.
fn consume(b: Box<int>) -> int {
    return Box::unwrap(b);
}

fn main() -> int {
    let x = Box::new(10);
    let mut i = 0;
    while i < 2 {
        consume(x);
        i = i + 1;
    }
    return 0;
}
