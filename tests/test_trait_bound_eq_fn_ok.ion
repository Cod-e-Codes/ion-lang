// Generic function with Eq bound: function pointers support ==
fn add_one(x: int) -> int {
    return x + 1;
}

fn same_fn<T: Eq>(a: T, b: T) -> bool {
    return a == b;
}

fn main() -> int {
    let f: fn(int) -> int = add_one;
    let g: fn(int) -> int = add_one;
    if same_fn(f, g) {
        return 99;
    }
    return 1;
}
