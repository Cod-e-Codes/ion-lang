// Vec drop inside an else-if branch (synthetic else block + nested if scopes).
fn main() -> int {
    let x: int = 2;

    if x == 1 {
        return 1;
    } else if x == 2 {
        let mut v: Vec<int> = Vec::new();
        Vec::push(&mut v, 42);
        return 0;
    }

    return 1;
}
