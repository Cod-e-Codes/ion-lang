import "../stdlib/fs.ion" as fs;

fn main() -> int {
    let path: String = "fixtures/small.txt";
    match fs::read_to_string_result(path) {
        ReadResult::Ok(raw) => {
            let content: String = raw;
            let expected: String = "hello ion\n";
            if content != expected {
                return 1;
            }
            return 80;
        },
        ReadResult::Err(_) => {
            return 2;
        },
    };
}
