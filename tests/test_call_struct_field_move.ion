struct Item {
    done: bool;
}

struct Batch {
    items: Vec<Item>;
}

fn take(items: Vec<Item>) -> int {
    let mut open: int = 0;
    for item in items {
        if !item.done {
            open = open + 1;
        }
    }
    return open;
}

fn main() -> int {
    let mut items: Vec<Item> = Vec::new();
    Vec::push(&mut items, Item { done: false });
    Vec::push(&mut items, Item { done: true });
    let batch: Batch = Batch { items: items };
    let open: int = take(batch.items);
    return open;
}
