enum Option<T> {
    Some(T);
    None;
}

fn main() -> int {
    let mut v: Vec<int> = Vec::new();
    Vec::push(&mut v, 7);
    match Vec::get_ref(&v, -1) {
        Option::Some(_) => {
            return 1;
        }
        Option::None => {}
    };
    match Vec::get_ref(&v, 1) {
        Option::Some(_) => {
            return 2;
        }
        Option::None => {}
    };
    match Vec::get_ref(&v, 0) {
        Option::Some(x) => {
            if x != 7 {
                return 3;
            }
        }
        Option::None => {
            return 4;
        }
    };
    return 0;
}
