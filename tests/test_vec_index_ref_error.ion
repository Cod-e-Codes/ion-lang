// Helper that almost returns &vec[i] via indexing (no-escape).
enum Option<T> {
    Some(T);
    None;
}

fn get_elem(values: &Vec<int>, idx: int) -> &int {
    match Vec::get(values, idx) {
        Option::Some(v) => {
            return &v;
        }
        Option::None => {
            let zero: int = 0;
            return &zero;
        }
    };
}

fn main() -> int {
    let mut v: Vec<int> = Vec::new();
    Vec::push(&mut v, 42);
    let _r: &int = get_elem(&v, 0);
    return 0;
}
